# =============================================================================
# docx-formatter — environment configuration
# Copy to .env in project root and adjust. Never commit real secrets.
# =============================================================================

# --- Application ---
APP_NAME=DocxFormatter
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
FRONTEND_URL=http://localhost:5173
MAX_UPLOAD_MB=150
PUBLISHED_INLINE_IMAGE_MAX_MB=2
PUBLISHED_INLINE_IMAGE_TOTAL_BUDGET_MB=32
LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- Production (IP-only access, docker-compose.prod.yml + Caddy) ---
# Replace <VPS_IP> with your server public IPv4 address.
# APP_URL=http://<VPS_IP>
# FRONTEND_URL=http://<VPS_IP>
# GRAFANA_ROOT_URL=http://<VPS_IP>:3001

# --- HTTP Basic Auth (Caddy reverse proxy, plain HTTP) ---
# Generate hash: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'your-password'
# BASIC_AUTH_USER=admin
# BASIC_AUTH_HASH=
# GRAFANA_BASIC_AUTH_USER=admin
# GRAFANA_BASIC_AUTH_HASH=

# --- Grafana (internal UI login + alerting) ---
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=change_me
# Update deploy/grafana/provisioning/alerting/contact-points.yml with real email for alerts.

# --- Queue workers (Laravel Horizon) ---
# HORIZON_MAX_PROCESSES=5

# --- Database (Docker: postgres) ---
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=docx_formatter
DB_USERNAME=docx
DB_PASSWORD=secret

# --- Redis & queue (Docker: redis + Horizon worker) ---
# Use QUEUE_CONNECTION=sync for local debugging without worker
REDIS_HOST=redis
REDIS_PORT=6379
QUEUE_CONNECTION=redis
# Must be >= Horizon job timeout (default 600s)
QUEUE_RETRY_AFTER=650
CACHE_STORE=redis

# --- S3-compatible storage ---
# Required when MOCK_STORAGE=false
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=
S3_REGION=ru-1
# Folder prefix inside the bucket (isolates app files if bucket is shared)
S3_PATH_PREFIX=docx-formatter

# --- Yandex AI Studio ---
# Required when MOCK_TRANSLATION=false
# Use API key of service account (not Object Storage access key)
YANDEX_AI_API_KEY=
YANDEX_AI_FOLDER_ID=
YANDEX_AI_TRANSLATE_MODEL=yandexgpt

# --- Translation performance ---
TRANSLATE_BATCH_SIZE=30
TRANSLATE_BATCH_CHAR_BUDGET=6000
TRANSLATE_CONCURRENCY=3
TRANSLATE_CACHE_ENABLED=true
TRANSLATE_CACHE_TTL_DAYS=30

# --- DOCX processing ---
DOCX_WRITE_TRANSLATED=false

# --- Mock integrations (development defaults) ---
MOCK_YANDEX=true
MOCK_STORAGE=true
MOCK_TRANSLATION=true
MOCK_NORMALIZER=true
MOCK_STORAGE_PATH=mock-cloud
TRANSLATION_GLOSSARY={}
MOCK_TRANSLATE_ENABLED=false
MOCK_TRANSLATE_PREFIX=[RU]

# =============================================================================
# Production checklist (fill on VPS manually):
#   APP_ENV=production
#   APP_DEBUG=false
#   LOG_CHANNEL=stderr
#   LOG_LEVEL=info
#   MOCK_STORAGE=false
#   MOCK_TRANSLATION=false
#   MOCK_NORMALIZER=false
#   MOCK_YANDEX=false
#   APP_URL=http://<VPS_IP>
#   FRONTEND_URL=http://<VPS_IP>
#   GRAFANA_ROOT_URL=http://<VPS_IP>:3001
#   BASIC_AUTH_* / GRAFANA_BASIC_AUTH_*
#   S3_* and YANDEX_AI_*
# =============================================================================
