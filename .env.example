# =============================================================================
# docx-formatter — environment configuration
# Copy to .env and adjust. Never commit real secrets.
# =============================================================================

# --- Application ---
APP_NAME=DocxFormatter
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
FRONTEND_URL=http://localhost:5173
MAX_UPLOAD_MB=50
REQUIRE_AUTH=false

# --- Database (Docker: postgres) ---
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=docx_formatter
DB_USERNAME=docx
DB_PASSWORD=secret

# --- Redis & queue (Docker: redis + queue worker) ---
# Use QUEUE_CONNECTION=sync for local debugging without worker
REDIS_HOST=redis
REDIS_PORT=6379
QUEUE_CONNECTION=redis

# --- Yandex Object Storage (S3-compatible) ---
# Required when MOCK_STORAGE=false
YC_STORAGE_BUCKET=
YC_STORAGE_KEY=
YC_STORAGE_SECRET=
YC_STORAGE_ENDPOINT=https://storage.yandexcloud.net
YC_STORAGE_REGION=ru-central1

# --- Yandex AI Studio ---
# Required when MOCK_TRANSLATION=false
# Use API key of service account (not Object Storage access key)
YANDEX_AI_API_KEY=
YANDEX_AI_FOLDER_ID=
YANDEX_AI_TRANSLATE_MODEL=yandexgpt

# --- DOCX processing ---
# Write translated text back into source DOCX during pipeline
DOCX_WRITE_TRANSLATED=false

# --- Mock integrations (can be mixed) ---
# Legacy fallback: sets MOCK_STORAGE and MOCK_TRANSLATION when unset
MOCK_YANDEX=true
# Local disk instead of Yandex Object Storage
MOCK_STORAGE=true
# Passthrough translator + mock block normalizer
MOCK_TRANSLATION=true
# When MOCK_TRANSLATION=true: prefix stub translation
MOCK_TRANSLATE_ENABLED=false
MOCK_TRANSLATE_PREFIX=[RU]
